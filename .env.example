# OpenChargeMap API anahtarı — https://openchargemap.org/site/develop/api
VITE_OCM_API_KEY=your-openchargemap-api-key

# Supabase — Proje Ayarları > API bölümünden alınır
# (publishable/anon anahtar; tarayıcıda kullanılır, gizli değildir)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Risk testi sonuçlarını kaydeden admin API uç noktası (service role ile RLS'yi atlar)
# Dev: http://localhost:8001/api/risk-results  ·  Prod: https://panel.alanadiniz.com/api/risk-results
VITE_RISK_API_URL=http://localhost:8001/api/risk-results

# Google Analytics 4 ölçüm kimliği
VITE_GA_ID=G-XXXXXXXXXX
