    "seed:blog": "node scripts/seed-blog.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.78.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.19.43",
    "pg": "^8.21.0",
    "playwright": "^1.61.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}
