{
  "name": "sarj-istasyonum-guvende",
  "version": "1.0.0",
  "description": "Elektrikli araç şarj istasyonu sigortası tanıtım sitesi (Vite + TypeScript)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
